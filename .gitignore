# Never commit minified files — LiteSpeed handles compression in production
assets/js/*.min.js
assets/css/*.min.css
*.min.js
*.min.css
*.min
.DS_Store
*.php.save
VERSION

# Whitelist vendored third-party assets (must ship in the release zip) —
# these override the *.min.js / *.min.css ignore rules above.
!assets/vendor/
!assets/vendor/**
